PROJECT_PAUSE_JSON=""
if [[ -n "$PROJECT" ]]; then
  PROJECT_PAUSE_JSON="$(resolve_project_pause "$PROJECT")"
fi

SESSION_ID="${RESUME_SESSION_ID:-}"
RESUME_CONTEXT=""
if [[ -n "$PROJECT" ]]; then
  if [[ -z "$SESSION_ID" ]]; then
    if [[ "$NO_AUTO_RESUME" != "1" ]]; then
      RESUME_CONTEXT="$(resolve_resume_context "$PROJECT")"
      if [[ -n "$RESUME_CONTEXT" ]]; then
        {
          IFS= read -r BOARD_SCOPE
          IFS= read -r BINDING_BOARD_PATH
          IFS= read -r TOPIC_NAME
          IFS= read -r ROLLUP_TARGET
          IFS= read -r SESSION_ID
        } < <(parse_binding_json "$RESUME_CONTEXT")
        BOARD_SCOPE="${BOARD_SCOPE:-project}"
        BINDING_BOARD_PATH="${BINDING_BOARD_PATH:-}"
        TOPIC_NAME="${TOPIC_NAME:-}"
        ROLLUP_TARGET="${ROLLUP_TARGET:-}"
        SESSION_ID="${SESSION_ID:-}"
      fi
    fi
  fi
  if [[ -n "$PROMPT" ]]; then
    BINDING_JSON="$(resolve_board_binding "$PROJECT" "$PROMPT")"
    {
      IFS= read -r BOARD_SCOPE
      IFS= read -r BINDING_BOARD_PATH
      IFS= read -r TOPIC_NAME
      IFS= read -r ROLLUP_TARGET
      IFS= read -r _
    } < <(parse_binding_json "$BINDING_JSON")
    BOARD_SCOPE="${BOARD_SCOPE:-project}"
    BINDING_BOARD_PATH="${BINDING_BOARD_PATH:-}"
    TOPIC_NAME="${TOPIC_NAME:-}"
    ROLLUP_TARGET="${ROLLUP_TARGET:-}"
  fi
fi

export CODEX_PROJECT_NAME="${PROJECT:-general}"
export CODEX_VAULT_PATH="$VAULT_ROOT"
export CODEX_MEMORY_MODE="strict-minimal"
SELECTED_MODEL="$(python3 -c 'import json,sys; payload=json.loads(sys.stdin.read() or "{}"); print(str(payload.get("model","")).strip())' <<<"$(resolve_codex_settings)")"
SELECTED_REASONING_EFFORT="$(python3 -c 'import json,sys; payload=json.loads(sys.stdin.read() or "{}"); print(str(payload.get("reasoning_effort","")).strip())' <<<"$(resolve_codex_settings)")"
CONTEXT_JSON="$(load_context_suggestions "${PROJECT:-}" "$PROMPT")"
if [[ "$DRY_RUN" != "1" && -n "$PROMPT" ]]; then
  if [[ -z "$PROJECT_PAUSE_JSON" || "$(pause_active "$PROJECT_PAUSE_JSON")" != "1" ]]; then
    CONTEXT_JSON="$(maybe_start_gflow_runtime "$CONTEXT_JSON" "${PROJECT:-}" "$PROMPT" "$SESSION_ID")"
  fi
fi

cd "$WORKSPACE_ROOT"

if [[ "$DRY_RUN" != "1" ]]; then
  ensure_obsidian_background
fi

if [[ -n "$SESSION_ID" ]]; then
  if [[ -z "$PROJECT" ]]; then
    if [[ "$DRY_RUN" == "1" ]]; then
      printf 'mode=resume\nproject=general\nsession_id=%s\nvault=%s\n' "$SESSION_ID" "$VAULT_ROOT"
      printf 'launch_source=%s\nchat_ref=%s\nthread_name=%s\nthread_label=%s\nattachment_type=%s\nattachment_path=%s\nmodel=%s\nreasoning_effort=%s\n' "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" "$SOURCE_THREAD_NAME" "$SOURCE_THREAD_LABEL" "$ATTACHMENT_TYPE" "$ATTACHMENT_PATH" "$SELECTED_MODEL" "$SELECTED_REASONING_EFFORT"
      printf 'launch_context_json=%s\n' "$(build_launch_context_json "resume" "general" "chat" "" "" "" "$SESSION_ID" "$EXECUTION_PROFILE" "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" "$SOURCE_THREAD_NAME" "$SOURCE_THREAD_LABEL" "$ATTACHMENT_PATH" "$ATTACHMENT_TYPE" "$VOICE_TRANSCRIPT" "$SELECTED_MODEL" "$SELECTED_REASONING_EFFORT")"
      print_feishu_ops_summary
      print_launcher_prompt_preview "$(build_codex_prompt "$PROMPT" "resume")"
      print_context_summary "$CONTEXT_JSON"
      exit 0
    fi
    echo "Routing: project=general mode=resume session=$SESSION_ID" >&2
    printf 'WORKSPACE_HUB_LAUNCH_CONTEXT=%s\n' "$(build_launch_context_json "resume" "general" "chat" "" "" "" "$SESSION_ID" "$EXECUTION_PROFILE" "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" "$SOURCE_THREAD_NAME" "$SOURCE_THREAD_LABEL" "$ATTACHMENT_PATH" "$ATTACHMENT_TYPE" "$VOICE_TRANSCRIPT" "$SELECTED_MODEL" "$SELECTED_REASONING_EFFORT")" >&2
    print_context_summary "$CONTEXT_JSON" >&2
    run_codex "" "resume" "$SESSION_ID"
    exit $?
  fi
  if [[ "$DRY_RUN" == "1" ]]; then
    printf 'mode=resume\nproject=%s\nsession_id=%s\nvault=%s\n' "$PROJECT" "$SESSION_ID" "$VAULT_ROOT"
    printf 'launch_source=%s\nchat_ref=%s\nthread_name=%s\nthread_label=%s\nattachment_type=%s\nattachment_path=%s\nmodel=%s\nreasoning_effort=%s\n' "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" "$SOURCE_THREAD_NAME" "$SOURCE_THREAD_LABEL" "$ATTACHMENT_TYPE" "$ATTACHMENT_PATH" "$SELECTED_MODEL" "$SELECTED_REASONING_EFFORT"
    printf 'launch_context_json=%s\n' "$(build_launch_context_json "resume" "$PROJECT" "$BOARD_SCOPE" "$BINDING_BOARD_PATH" "$TOPIC_NAME" "$ROLLUP_TARGET" "$SESSION_ID" "$EXECUTION_PROFILE" "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" "$SOURCE_THREAD_NAME" "$SOURCE_THREAD_LABEL" "$ATTACHMENT_PATH" "$ATTACHMENT_TYPE" "$VOICE_TRANSCRIPT" "$SELECTED_MODEL" "$SELECTED_REASONING_EFFORT")"
    print_feishu_ops_summary
    print_launcher_prompt_preview "$(build_codex_prompt "$PROMPT" "resume")"
    if [[ -n "$PROJECT_PAUSE_JSON" ]]; then
      printf 'pause_active=%s\npause_summary=%s\n' "$(pause_active "$PROJECT_PAUSE_JSON")" "$(pause_summary "$PROJECT_PAUSE_JSON")"
    fi
    print_context_summary "$CONTEXT_JSON"
    exit 0
  fi
  if [[ -n "$PROJECT_PAUSE_JSON" && "$(pause_active "$PROJECT_PAUSE_JSON")" == "1" ]]; then
    echo "Routing blocked: $(pause_summary "$PROJECT_PAUSE_JSON")" >&2
    exit 0
  fi
  echo "Routing: project=$PROJECT mode=resume session=$SESSION_ID" >&2
  printf 'WORKSPACE_HUB_LAUNCH_CONTEXT=%s\n' "$(build_launch_context_json "resume" "$PROJECT" "$BOARD_SCOPE" "$BINDING_BOARD_PATH" "$TOPIC_NAME" "$ROLLUP_TARGET" "$SESSION_ID" "$EXECUTION_PROFILE" "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" "$SOURCE_THREAD_NAME" "$SOURCE_THREAD_LABEL" "$ATTACHMENT_PATH" "$ATTACHMENT_TYPE" "$VOICE_TRANSCRIPT" "$SELECTED_MODEL" "$SELECTED_REASONING_EFFORT")" >&2
  print_context_summary "$CONTEXT_JSON" >&2
  LAUNCH_ID="$(python3 "$MEMORY_TOOL" register-launch --project-name "$PROJECT" --prompt "$PROMPT" --mode resume --resume-session-id "$SESSION_ID" --binding-scope "$BOARD_SCOPE" --binding-board-path "$BINDING_BOARD_PATH" --topic-name "$TOPIC_NAME" --rollup-target "$ROLLUP_TARGET" --launch-source "$LAUNCH_SOURCE" --source-chat-ref "$SOURCE_CHAT_REF" --source-thread-name "$SOURCE_THREAD_NAME" --source-thread-label "$SOURCE_THREAD_LABEL" --source-message-id "$SOURCE_MESSAGE_ID")"
  run_codex "$LAUNCH_ID" "resume" "$SESSION_ID"
  exit $?
fi

if [[ -n "$PROJECT" ]]; then
  if [[ "$DRY_RUN" == "1" ]]; then
    printf 'mode=new\nproject=%s\nsession_id=\nvault=%s\n' "$PROJECT" "$VAULT_ROOT"
    printf 'launch_source=%s\nchat_ref=%s\nthread_name=%s\nthread_label=%s\nattachment_type=%s\nattachment_path=%s\nmodel=%s\nreasoning_effort=%s\n' "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" "$SOURCE_THREAD_NAME" "$SOURCE_THREAD_LABEL" "$ATTACHMENT_TYPE" "$ATTACHMENT_PATH" "$SELECTED_MODEL" "$SELECTED_REASONING_EFFORT"
    printf 'launch_context_json=%s\n' "$(build_launch_context_json "new" "$PROJECT" "$BOARD_SCOPE" "$BINDING_BOARD_PATH" "$TOPIC_NAME" "$ROLLUP_TARGET" "" "$EXECUTION_PROFILE" "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" "$SOURCE_THREAD_NAME" "$SOURCE_THREAD_LABEL" "$ATTACHMENT_PATH" "$ATTACHMENT_TYPE" "$VOICE_TRANSCRIPT" "$SELECTED_MODEL" "$SELECTED_REASONING_EFFORT")"
    print_feishu_ops_summary
    print_launcher_prompt_preview "$(build_codex_prompt "$PROMPT" "new")"
    if [[ -n "$PROJECT_PAUSE_JSON" ]]; then
      printf 'pause_active=%s\npause_summary=%s\n' "$(pause_active "$PROJECT_PAUSE_JSON")" "$(pause_summary "$PROJECT_PAUSE_JSON")"
    fi
    print_context_summary "$CONTEXT_JSON"
    exit 0
  fi
  if [[ -n "$PROJECT_PAUSE_JSON" && "$(pause_active "$PROJECT_PAUSE_JSON")" == "1" ]]; then
    echo "Routing blocked: $(pause_summary "$PROJECT_PAUSE_JSON")" >&2
    exit 0
  fi
  echo "Routing: project=$PROJECT mode=new" >&2
  printf 'WORKSPACE_HUB_LAUNCH_CONTEXT=%s\n' "$(build_launch_context_json "new" "$PROJECT" "$BOARD_SCOPE" "$BINDING_BOARD_PATH" "$TOPIC_NAME" "$ROLLUP_TARGET" "" "$EXECUTION_PROFILE" "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" "$SOURCE_THREAD_NAME" "$SOURCE_THREAD_LABEL" "$ATTACHMENT_PATH" "$ATTACHMENT_TYPE" "$VOICE_TRANSCRIPT" "$SELECTED_MODEL" "$SELECTED_REASONING_EFFORT")" >&2
  print_context_summary "$CONTEXT_JSON" >&2
  if [[ -z "$BINDING_BOARD_PATH" ]]; then
    BINDING_JSON="$(resolve_board_binding "$PROJECT" "$PROMPT")"
    {
      IFS= read -r BOARD_SCOPE
      IFS= read -r BINDING_BOARD_PATH
      IFS= read -r TOPIC_NAME
      IFS= read -r ROLLUP_TARGET
      IFS= read -r _
    } < <(parse_binding_json "$BINDING_JSON")
    BOARD_SCOPE="${BOARD_SCOPE:-project}"
    BINDING_BOARD_PATH="${BINDING_BOARD_PATH:-}"
    TOPIC_NAME="${TOPIC_NAME:-}"
    ROLLUP_TARGET="${ROLLUP_TARGET:-}"
  fi
  LAUNCH_ID="$(python3 "$MEMORY_TOOL" register-launch --project-name "$PROJECT" --prompt "$PROMPT" --mode new --binding-scope "$BOARD_SCOPE" --binding-board-path "$BINDING_BOARD_PATH" --topic-name "$TOPIC_NAME" --rollup-target "$ROLLUP_TARGET" --launch-source "$LAUNCH_SOURCE" --source-chat-ref "$SOURCE_CHAT_REF" --source-thread-name "$SOURCE_THREAD_NAME" --source-thread-label "$SOURCE_THREAD_LABEL" --source-message-id "$SOURCE_MESSAGE_ID")"
else
  if [[ "$DRY_RUN" == "1" ]]; then
    printf 'mode=general\nproject=general\nsession_id=\nvault=%s\n' "$VAULT_ROOT"
    printf 'launch_source=%s\nchat_ref=%s\nthread_name=%s\nthread_label=%s\nattachment_type=%s\nattachment_path=%s\nmodel=%s\nreasoning_effort=%s\n' "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" "$SOURCE_THREAD_NAME" "$SOURCE_THREAD_LABEL" "$ATTACHMENT_TYPE" "$ATTACHMENT_PATH" "$SELECTED_MODEL" "$SELECTED_REASONING_EFFORT"
    printf 'launch_context_json=%s\n' "$(build_launch_context_json "general" "general" "chat" "" "" "" "" "$EXECUTION_PROFILE" "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" "$SOURCE_THREAD_NAME" "$SOURCE_THREAD_LABEL" "$ATTACHMENT_PATH" "$ATTACHMENT_TYPE" "$VOICE_TRANSCRIPT" "$SELECTED_MODEL" "$SELECTED_REASONING_EFFORT")"
    print_feishu_ops_summary
    print_launcher_prompt_preview "$(build_codex_prompt "$PROMPT" "new")"
    print_context_summary "$CONTEXT_JSON"
    exit 0
  fi
  echo "Routing: project=general mode=new" >&2
  printf 'WORKSPACE_HUB_LAUNCH_CONTEXT=%s\n' "$(build_launch_context_json "general" "general" "chat" "" "" "" "" "$EXECUTION_PROFILE" "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" "$SOURCE_THREAD_NAME" "$SOURCE_THREAD_LABEL" "$ATTACHMENT_PATH" "$ATTACHMENT_TYPE" "$VOICE_TRANSCRIPT" "$SELECTED_MODEL" "$SELECTED_REASONING_EFFORT")" >&2
  print_context_summary "$CONTEXT_JSON" >&2
fi

if [[ -n "$PROJECT" ]]; then
  run_codex "$LAUNCH_ID" "new" ""
  exit $?
fi

if [[ -n "$PROMPT" ]]; then
  run_codex "" "new" ""
  exit $?
fi

codex -C "$WORKSPACE_ROOT"
