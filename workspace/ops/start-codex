maybe_start_gflow_runtime() {
  python3 - "$CODE_ROOT" "$1" "$2" "$3" "$4" <<'PY'
import json
import sys

code_root, context_json, project_name, prompt, session_id = sys.argv[1:6]
sys.path.insert(0, str(code_root))

from ops import gstack_automation  # noqa: E402

try:
    context = json.loads(context_json or "{}")
except Exception:
    context = {}

if not str(prompt or "").strip():
    print(json.dumps(context, ensure_ascii=False))
    raise SystemExit(0)

gflow = context.get("gflow_recommendation") or {}
if str(gflow.get("invocation_mode", "")).strip() != "gflow-explicit":
    print(json.dumps(context, ensure_ascii=False))
    raise SystemExit(0)
if str(gflow.get("status", "")).strip() == "gflow-recommendation-error":
    print(json.dumps(context, ensure_ascii=False))
    raise SystemExit(0)

payload = gstack_automation.start_explicit_workflow_run_if_requested(
    prompt,
    project_name=str(project_name or "").strip(),
    session_id=str(session_id or "").strip(),
)
if not payload.get("started"):
    print(json.dumps(context, ensure_ascii=False))
    raise SystemExit(0)

project_name = str(project_name or "").strip()
if project_name:
    runtime_summary = gstack_automation.latest_project_workflow_summary(project_name)
else:
    run_summary = payload.get("run_summary") or {}
    runtime_summary = {
        "run_id": str(payload.get("run_id", "")).strip(),
        "run_status": str(payload.get("run_status", "")).strip(),
        "current_stage": str(payload.get("current_stage", "")).strip(),
        "template_id": str(payload.get("template_id", "")).strip(),
        "template_label": str(payload.get("template_label", "")).strip(),
        "latest_summary": str(payload.get("latest_summary", "")).strip() or str(run_summary.get("summary", "")).strip(),
        "latest_next_action": str(payload.get("latest_next_action", "")).strip() or str(run_summary.get("next_action", "")).strip(),
        "updated_at": str(payload.get("updated_at", "")).strip() or str(run_summary.get("updated_at", "")).strip(),
        "gate": dict(payload.get("gate") or {}),
        "suggested_path": list(payload.get("suggested_path", [])),
    }

context["gflow_runtime_summary"] = runtime_summary
context["gflow_started_run"] = {
    "run_id": str(payload.get("run_id", "")).strip(),
    "run_status": str(payload.get("run_status", "")).strip(),
    "current_stage": str(payload.get("current_stage", "")).strip(),
    "template_id": str(payload.get("template_id", "")).strip(),
    "template_label": str(payload.get("template_label", "")).strip(),
}
execution_contract = gstack_automation.build_runtime_execution_contract(payload)
if execution_contract:
    context["gflow_execution_contract"] = execution_contract
print(json.dumps(context, ensure_ascii=False))
PY
}

