#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CODE_ROOT="${WORKSPACE_HUB_CODE_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
DEFAULT_WORKSPACE_ROOT="$CODE_ROOT"
DEFAULT_VAULT_ROOT="$(cd "$CODE_ROOT/../memory" && pwd)"
# Code may come from a worktree, but runtime/control state should keep using the
# canonical workspace unless the caller explicitly overrides it.
WORKSPACE_ROOT="${WORKSPACE_HUB_ROOT:-$DEFAULT_WORKSPACE_ROOT}"
VAULT_ROOT="${WORKSPACE_HUB_VAULT_ROOT:-$DEFAULT_VAULT_ROOT}"
REGISTRY_MD="$VAULT_ROOT/PROJECT_REGISTRY.md"
SESSION_ROUTER="$WORKSPACE_ROOT/runtime/session-router.json"
PROJECT_BINDINGS_JSON="$WORKSPACE_ROOT/runtime/project-bindings.json"
MEMORY_TOOL="$CODE_ROOT/ops/codex_memory.py"
CONTEXT_TOOL="$CODE_ROOT/ops/codex_context.py"
MATERIAL_ROUTER_TOOL="$CODE_ROOT/ops/material_router.py"
PROJECTS_ROOT="${WORKSPACE_HUB_PROJECTS_ROOT:-$WORKSPACE_ROOT/projects}"

PROJECT=""
PROMPT=""
DRY_RUN="0"
AUTO_OPEN_OBSIDIAN="1"
BOARD_SCOPE="project"
BINDING_BOARD_PATH=""
TOPIC_NAME=""
ROLLUP_TARGET=""
EXECUTION_PROFILE=""
MODEL_NAME=""
REASONING_EFFORT=""
RESUME_SESSION_ID=""
NO_AUTO_RESUME="0"
LAUNCH_SOURCE=""
SOURCE_CHAT_REF=""
SOURCE_THREAD_NAME=""
SOURCE_THREAD_LABEL=""
SOURCE_MESSAGE_ID=""
ATTACHMENT_PATH=""
ATTACHMENT_TYPE=""
VOICE_TRANSCRIPT=""
APPROVAL_TOKEN=""

usage() {
  cat <<'EOF'
Usage:
  start-codex --project <name> [--prompt "<text>"]
  start-codex --prompt "<text>"
  start-codex --resume-session-id <session> [--prompt "<text>"]
  start-codex --no-auto-resume [--project <name>] [--prompt "<text>"]
  start-codex --no-open-obsidian [--project <name>] [--prompt "<text>"]
  start-codex --dry-run [--project <name>] [--prompt "<text>"]
  start-codex

Behavior:
  - Starts from the current Codex Hub workspace root
  - Does not require Obsidian to be manually opened first
  - By default, ensures Obsidian is available in the background for the Vault
  - If a project is resolved and a same-project session exists within 24 hours,
    resumes that session
  - If --prompt is provided, the script uses non-interactive codex exec mode
  - If no project is resolved, starts in general mode
  - If --dry-run is provided, prints the routing decision and exits
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project)
      PROJECT="${2:-}"
      shift 2
      ;;
    --prompt)
      PROMPT="${2:-}"
      shift 2
      ;;
    --execution-profile)
      EXECUTION_PROFILE="${2:-}"
      shift 2
      ;;
    --model)
      MODEL_NAME="${2:-}"
      shift 2
      ;;
    --reasoning-effort)
      REASONING_EFFORT="${2:-}"
      shift 2
      ;;
    --resume-session-id)
      RESUME_SESSION_ID="${2:-}"
      shift 2
      ;;
    --no-auto-resume)
      NO_AUTO_RESUME="1"
      shift
      ;;
    --source)
      LAUNCH_SOURCE="${2:-}"
      shift 2
      ;;
    --chat-ref)
      SOURCE_CHAT_REF="${2:-}"
      shift 2
      ;;
    --thread-name)
      SOURCE_THREAD_NAME="${2:-}"
      shift 2
      ;;
    --thread-label)
      SOURCE_THREAD_LABEL="${2:-}"
      shift 2
      ;;
    --source-message-id)
      SOURCE_MESSAGE_ID="${2:-}"
      shift 2
      ;;
    --attachment-path)
      ATTACHMENT_PATH="${2:-}"
      shift 2
      ;;
    --attachment-type)
      ATTACHMENT_TYPE="${2:-}"
      shift 2
      ;;
    --voice-transcript)
      VOICE_TRANSCRIPT="${2:-}"
      shift 2
      ;;
    --approval-token)
      APPROVAL_TOKEN="${2:-}"
      shift 2
      ;;
    --dry-run)
      DRY_RUN="1"
      shift
      ;;
    --no-open-obsidian)
      AUTO_OPEN_OBSIDIAN="0"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [[ -z "$PROMPT" ]]; then
        PROMPT="$1"
      else
        PROMPT="$PROMPT $1"
      fi
      shift
      ;;
  esac
done

resolve_project_from_prompt() {
  python3 - "$REGISTRY_MD" "$PROMPT" "$PROJECTS_ROOT" <<'PY'
import json, re, sys
from pathlib import Path

path, prompt, projects_root = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    text = open(path, "r", encoding="utf-8").read()
except FileNotFoundError:
    text = ""
data = []
if text:
    match = re.search(r"<!-- PROJECT_REGISTRY_DATA_START -->\s*```json\s*(.*?)\s*```\s*<!-- PROJECT_REGISTRY_DATA_END -->", text, re.S)
    if match:
        try:
            data = json.loads(match.group(1))
        except Exception:
            data = []
known = {item.get("project_name", ""): item for item in data if item.get("project_name")}
try:
    for child in sorted(Path(projects_root).iterdir(), key=lambda item: item.name.lower()):
        if not child.is_dir() or child.name.startswith("."):
            continue
        if child.name not in known:
            known[child.name] = {
                "project_name": child.name,
                "aliases": [child.name.lower()] if child.name.lower() != child.name else [],
            }
except FileNotFoundError:
    pass
prompt_l = prompt.lower()
hits = []
for item in known.values():
    names = [item.get("project_name", "")] + list(item.get("aliases", []))
    for name in names:
        if name and name.lower() in prompt_l:
            hits.append(item["project_name"])
            break
hits = sorted(set(hits))
print(hits[0] if len(hits) == 1 else "")
PY
}

canonicalize_project_name() {
  python3 - "$REGISTRY_MD" "$1" <<'PY'
import json, re, sys

path, project = sys.argv[1], sys.argv[2]
project = project.strip()
if not project:
    print("")
    raise SystemExit(0)
try:
    text = open(path, "r", encoding="utf-8").read()
except FileNotFoundError:
    text = ""
data = []
if text:
    match = re.search(r"<!-- PROJECT_REGISTRY_DATA_START -->\s*```json\s*(.*?)\s*```\s*<!-- PROJECT_REGISTRY_DATA_END -->", text, re.S)
    if match:
        try:
            data = json.loads(match.group(1))
        except Exception:
            data = []
project_l = project.lower()
for item in data:
    names = [item.get("project_name", "")] + list(item.get("aliases", []))
    for name in names:
        if name and name.lower() == project_l:
            print(item.get("project_name", project))
            raise SystemExit(0)
print(project)
PY
}

resolve_resume_context() {
  python3 - "$SESSION_ROUTER" "$PROJECT_BINDINGS_JSON" "$1" "$LAUNCH_SOURCE" "$SOURCE_CHAT_REF" <<'PY'
import json, sys, datetime as dt
path, bindings_path, project, launch_source, source_chat_ref = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5]
try:
    data = json.load(open(path, "r", encoding="utf-8"))
except Exception:
    print("")
    raise SystemExit(0)
route = data.get("routes", {}).get(project)
if not route:
    print("")
    raise SystemExit(0)
sid = route.get("last_session_id")
last_active = route.get("last_active_at")
route_launch_source = str(route.get("last_launch_source", "")).strip()
route_source_chat_ref = str(route.get("last_source_chat_ref", "")).strip()
launch_source = launch_source.strip()
source_chat_ref = source_chat_ref.strip()
if not sid or not last_active:
    print("")
    raise SystemExit(0)
try:
    ts = dt.datetime.fromisoformat(last_active.replace("Z", "+00:00"))
except Exception:
    print("")
    raise SystemExit(0)
if not route_launch_source and not route_source_chat_ref:
    try:
        bindings = json.load(open(bindings_path, "r", encoding="utf-8")).get("bindings", [])
    except Exception:
        bindings = []
    candidates = []
    for item in bindings:
        if str(item.get("project_name", "")).strip() != project:
            continue
        if str(item.get("session_id", "")).strip() != str(sid).strip():
            continue
        candidates.append(item)
    candidates.sort(
        key=lambda item: str(item.get("last_active_at", "") or item.get("started_at", "") or ""),
        reverse=True,
    )
    if candidates:
        latest = candidates[0]
        route_launch_source = str(latest.get("launch_source", "")).strip()
        route_source_chat_ref = str(latest.get("source_chat_ref", "")).strip()
now = dt.datetime.now(dt.timezone.utc)
if (now - ts).total_seconds() <= 24 * 3600:
    if route_launch_source or route_source_chat_ref:
        if not launch_source:
            print("")
            raise SystemExit(0)
        if route_launch_source and launch_source != route_launch_source:
            print("")
            raise SystemExit(0)
        if route_source_chat_ref and source_chat_ref != route_source_chat_ref:
            print("")
            raise SystemExit(0)
    print(json.dumps({
        "session_id": sid,
        "binding_scope": route.get("binding_scope", "project"),
        "binding_board_path": route.get("binding_board_path", ""),
        "topic_name": route.get("topic_name", ""),
        "rollup_target": route.get("rollup_target", ""),
        "last_launch_source": route_launch_source,
        "last_source_chat_ref": route_source_chat_ref,
    }, ensure_ascii=False))
else:
    print("")
PY
}

