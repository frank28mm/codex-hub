run_codex() {
  local launch_id="${1:-}"
  local mode="${2:-new}"
  local session_id="${3:-}"
  local output_file=""
  local status=0
  local codex_prompt="$PROMPT"
  local selected_model="${SELECTED_MODEL:-}"
  local selected_reasoning_effort="${SELECTED_REASONING_EFFORT:-}"
  local codex_path=""
  local node_path=""
  local -a codex_prefix=()
  local -a codex_exec_base=()
  local feishu_root=""
  local finalize_args=(
    python3 "$MEMORY_TOOL" finalize-launch
    --launch-id "$launch_id"
  )

  codex_path="$(command -v codex || true)"
  if [[ -z "$codex_path" && -x "$HOME/.npm-global/bin/codex" ]]; then
    codex_path="$HOME/.npm-global/bin/codex"
  fi
  if [[ -z "$codex_path" ]]; then
    codex_path="codex"
  fi
  node_path="$(command -v node || true)"
  if [[ -z "$node_path" && -x "/opt/homebrew/bin/node" ]]; then
    node_path="/opt/homebrew/bin/node"
  fi
  if [[ -z "$node_path" && -x "/usr/local/bin/node" ]]; then
    node_path="/usr/local/bin/node"
  fi

  if [[ -f "$codex_path" ]] && head -n 1 "$codex_path" 2>/dev/null | grep -q '^#!/usr/bin/env node' && [[ -n "$node_path" ]]; then
    codex_prefix=("$node_path" "$codex_path")
  else
    codex_prefix=("$codex_path")
  fi

  if ! validate_execution_profile_access; then
    return 1
  fi

  codex_exec_base=("${codex_prefix[@]}" "exec" "-C" "$WORKSPACE_ROOT")
  if [[ -n "$selected_model" ]]; then
    codex_exec_base+=("--model" "$selected_model")
  fi
  if [[ -n "$selected_reasoning_effort" ]]; then
    codex_exec_base+=("-c" "model_reasoning_effort=\"$selected_reasoning_effort\"")
  fi
  if [[ "$EXECUTION_PROFILE" == "feishu" || "$EXECUTION_PROFILE" == "weixin" || "$EXECUTION_PROFILE" == "feishu-object-op" || "$EXECUTION_PROFILE" == "feishu-local-extend" || "$EXECUTION_PROFILE" == "feishu-local-system-approved" || "$EXECUTION_PROFILE" == "feishu-approved" || "$EXECUTION_PROFILE" == "electron-full-access" ]]; then
    if [[ "$EXECUTION_PROFILE" == "feishu" || "$EXECUTION_PROFILE" == "weixin" || "$EXECUTION_PROFILE" == "feishu-object-op" || "$EXECUTION_PROFILE" == "feishu-local-extend" || "$EXECUTION_PROFILE" == "feishu-local-system-approved" ]]; then
      codex_exec_base+=("--sandbox" "workspace-write" "-c" 'approval_policy="never"' "-c" "sandbox_workspace_write.network_access=true")
      while IFS= read -r feishu_root; do
        [[ -n "$feishu_root" ]] || continue
        codex_exec_base+=("--add-dir" "$feishu_root")
      done < <(emit_execution_profile_roots)
    else
      codex_exec_base+=("--sandbox" "danger-full-access" "-c" 'approval_policy="never"')
    fi
  fi

  if [[ -n "$PROMPT" ]]; then
    codex_prompt="$(build_codex_prompt "$PROMPT" "$mode")"
  fi

  if [[ -n "$PROJECT" && -n "$PROMPT" && "$mode" == "new" ]]; then
    output_file="$WORKSPACE_ROOT/runtime/last-message-${launch_id}.txt"
    rm -f "$output_file"
    "${codex_exec_base[@]}" -o "$output_file" "$codex_prompt" || status=$?
  elif [[ -n "$PROJECT" && -n "$PROMPT" && "$mode" == "resume" ]]; then
    output_file="$WORKSPACE_ROOT/runtime/last-message-${launch_id}.txt"
    rm -f "$output_file"
    "${codex_exec_base[@]}" -o "$output_file" resume "$session_id" "$codex_prompt" || status=$?
  elif [[ -z "$PROJECT" && -n "$PROMPT" && "$mode" == "resume" && -n "$session_id" ]]; then
    output_file="$WORKSPACE_ROOT/runtime/last-message-${launch_id}.txt"
    rm -f "$output_file"
    "${codex_exec_base[@]}" -o "$output_file" resume "$session_id" "$codex_prompt" || status=$?
  elif [[ -n "$PROMPT" ]]; then
    "${codex_exec_base[@]}" "$codex_prompt" || status=$?
  elif [[ "$mode" == "resume" && -n "$session_id" ]]; then
    if [[ -n "$selected_model" ]]; then
      "${codex_prefix[@]}" resume --model "$selected_model" ${selected_reasoning_effort:+-c model_reasoning_effort=\"$selected_reasoning_effort\"} -C "$WORKSPACE_ROOT" "$session_id" || status=$?
    else
      "${codex_prefix[@]}" resume ${selected_reasoning_effort:+-c model_reasoning_effort=\"$selected_reasoning_effort\"} -C "$WORKSPACE_ROOT" "$session_id" || status=$?
    fi
  else
    if [[ -n "$selected_model" ]]; then
      "${codex_prefix[@]}" --model "$selected_model" ${selected_reasoning_effort:+-c model_reasoning_effort=\"$selected_reasoning_effort\"} -C "$WORKSPACE_ROOT" || status=$?
    else
      "${codex_prefix[@]}" ${selected_reasoning_effort:+-c model_reasoning_effort=\"$selected_reasoning_effort\"} -C "$WORKSPACE_ROOT" || status=$?
    fi
  fi

  if [[ -n "$launch_id" ]]; then
    local final_status="completed"
    if [[ "$status" -ne 0 ]]; then
      if [[ "$status" -eq 130 || "$status" -eq 143 ]]; then
        final_status="aborted"
      else
        final_status="failed"
      fi
    fi
    if [[ -n "$session_id" ]]; then
      finalize_args+=(--session-id "$session_id")
    fi
    if [[ -n "$SOURCE_THREAD_NAME" ]]; then
      finalize_args+=(--thread-name "$SOURCE_THREAD_NAME")
    fi
    if [[ -n "$output_file" ]]; then
      finalize_args+=(--summary-file "$output_file")
    fi
    finalize_args+=(--final-status "$final_status")
    local finalize_output=""
    finalize_output="$("${finalize_args[@]}" 2>/dev/null || true)"
    if [[ -n "$finalize_output" ]]; then
      printf 'WORKSPACE_HUB_FINALIZE_LAUNCH=%s\n' "$finalize_output" >&2
    fi
    rm -f "$output_file"
  fi

  return "$status"
}

