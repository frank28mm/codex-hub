emit_execution_profile_roots() {
  python3 - "$WORKSPACE_ROOT" "$VAULT_ROOT" "$EXECUTION_PROFILE" <<'PY'
from pathlib import Path
import sys

workspace_root = Path(sys.argv[1]).resolve()
vault_root = Path(sys.argv[2]).resolve()
execution_profile = str(sys.argv[3]).strip()
canonical_root = workspace_root
if workspace_root.parent.name == "workspace-hub-worktrees":
    sibling = workspace_root.parent.parent / "workspace-hub"
    if sibling.exists():
        canonical_root = sibling.resolve()
worktrees_root = canonical_root.parent / "workspace-hub-worktrees"
roots = [
    vault_root,
    canonical_root,
    canonical_root / "projects",
    workspace_root,
    workspace_root / "projects",
    worktrees_root / "core-v1-0-3-to-v1-0-5",
    worktrees_root / "feishu-bridge",
    worktrees_root / "electron-console",
]

codex_home = Path.home() / ".codex"
if execution_profile in {"feishu-local-extend", "feishu-local-system-approved"}:
    for extra in [codex_home, codex_home / "skills", codex_home / "agents"]:
        extra.mkdir(parents=True, exist_ok=True)
        roots.append(extra)

if execution_profile == "feishu-local-system-approved":
    launch_agents = Path.home() / "Library" / "LaunchAgents"
    launch_agents.mkdir(parents=True, exist_ok=True)
    roots.extend(
        [
            Path.home(),
            launch_agents,
            Path("/Applications"),
            Path("/usr/local/bin"),
            Path("/opt/homebrew/bin"),
        ]
    )

seen = set()
for root in roots:
    try:
        key = str(root.resolve())
    except FileNotFoundError:
        if not root.exists():
            continue
        key = str(root)
    if key in seen:
        continue
    seen.add(key)
    print(key)
PY
}

validate_execution_profile_access() {
  python3 - "$CODE_ROOT" "$EXECUTION_PROFILE" "$APPROVAL_TOKEN" "$LAUNCH_SOURCE" <<'PY'
import datetime as dt
import sys
from pathlib import Path

code_root = Path(sys.argv[1]).resolve()
execution_profile = str(sys.argv[2]).strip()
approval_token = str(sys.argv[3]).strip()
source = str(sys.argv[4]).strip()
sys.path.insert(0, str(code_root))

from ops import runtime_state  # noqa: E402

approved_map = {
    "feishu-approved": "feishu_high_risk_execution",
    "feishu-local-system-approved": "feishu_local_system_execution",
}

if not execution_profile:
    raise SystemExit(0)

if execution_profile == "electron-full-access":
    if source == "electron":
        raise SystemExit(0)
    print("electron-full-access requires --source electron", file=sys.stderr)
    raise SystemExit(1)

expected_scope = approved_map.get(execution_profile, "")
if not expected_scope:
    raise SystemExit(0)

if not approval_token:
    print(f"{execution_profile} requires --approval-token ({expected_scope})", file=sys.stderr)
    raise SystemExit(1)

item = runtime_state.fetch_approval_token(approval_token)
if not item.get("scope"):
    print(f"approval token {approval_token} not found", file=sys.stderr)
    raise SystemExit(1)
if str(item.get("status") or "").strip() != "approved":
    print(f"approval token {approval_token} is not approved", file=sys.stderr)
    raise SystemExit(1)
expires_at = runtime_state.parse_iso_timestamp(str(item.get("expires_at") or "").strip())
if expires_at is not None and expires_at <= dt.datetime.now(dt.timezone.utc):
    print(f"approval token {approval_token} is expired", file=sys.stderr)
    raise SystemExit(1)
scope = str(item.get("scope") or "").strip()
if scope != expected_scope:
    print(
        f"approval token {approval_token} scope mismatch: expected {expected_scope}, got {scope}",
        file=sys.stderr,
    )
    raise SystemExit(1)
metadata = item.get("metadata", {}) if isinstance(item.get("metadata"), dict) else {}
approved_profile = str(metadata.get("approved_execution_profile") or "feishu-approved").strip()
if approved_profile != execution_profile:
    print(
        f"approval token {approval_token} profile mismatch: expected {execution_profile}, got {approved_profile}",
        file=sys.stderr,
    )
    raise SystemExit(1)
PY
}

