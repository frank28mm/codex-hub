# Sample Feishu bridge environment for the v1.0.6 IM-first release.
# Default route is Electron-hosted long-connection + REST.

# FS-05: Electron-hosted IM bridge credentials
FEISHU_APP_ID=cli-app-id
FEISHU_APP_SECRET=cli-app-secret
FEISHU_OWNER_OPEN_ID=ou_xxx
FEISHU_DOMAIN=feishu
FEISHU_ALLOWED_USERS=ou_xxx,ou_yyy
FEISHU_GROUP_POLICY=mentions_only
FEISHU_REQUIRE_MENTION=true

# Official lark-cli transport / object backend.
# Keep these on `auto` to prefer the official CLI when available while preserving
# the existing CoCo semantics and bridge flow.
WORKSPACE_HUB_FEISHU_CLI_EVENT_TRANSPORT=auto
WORKSPACE_HUB_FEISHU_CLI_IM_TRANSPORT=auto
WORKSPACE_HUB_FEISHU_BACKEND=auto
WORKSPACE_HUB_FEISHU_BACKEND_DOMAINS=im doc drive contact table task calendar vc minutes wiki sheet mail whiteboard

# Optional compatibility mode only
FEISHU_VERIFICATION_TOKEN=compat-webhook-verification-token
FEISHU_SIGNING_SECRET=compat-webhook-signing-secret

# FS-06: read-only projection publishing (deferred from v1.0.6 gate)
FEISHU_BITABLE_APP_TOKEN=bitable-app-token
FEISHU_BITABLE_PROJECTS_TABLE_ID=tbl_projects
FEISHU_BITABLE_REVIEW_TABLE_ID=tbl_review
FEISHU_BITABLE_COORDINATION_TABLE_ID=tbl_coordination
FEISHU_BITABLE_HEALTH_TABLE_ID=tbl_health
